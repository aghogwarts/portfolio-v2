---
import { getCollection, render } from 'astro:content';
import Base from '../layouts/Base.astro';
import Nav  from '../components/Nav.astro';

const allTrips = await getCollection('trips');
const sorted   = allTrips.sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());
const cities   = ['All', ...new Set(allTrips.map(t => t.data.city))];
const totalKm  = allTrips.reduce((sum, t) => sum + (t.data.km ?? 0), 0);

const renderedTrips = await Promise.all(
  sorted.map(async trip => {
    const { Content } = await render(trip);
    return { trip, Content };
  })
);
---

<Base title="Journey — Ansh Goyal" description="Every ride, every place, every story.">
  <Nav page="journey" />

  <main class="journey-page">

    <!-- Header -->
    <div class="j-header container">
      <p class="j-eyebrow mono accent">// trip log</p>
      <h1 class="j-title">The<br />Journey</h1>
      <p class="j-sub mono">Every ride. Every place. Every story. — updated as I go.</p>
    </div>

    <!-- Stats -->
    <div class="container">
      <div class="j-stats">
        <div class="j-stat"><span class="j-stat-val">{allTrips.length}</span><span class="j-stat-lbl mono">Trips</span></div>
        <div class="j-stat"><span class="j-stat-val">{cities.length - 1}</span><span class="j-stat-lbl mono">Cities</span></div>
        <div class="j-stat"><span class="j-stat-val">{totalKm > 0 ? totalKm : '—'}</span><span class="j-stat-lbl mono">km ridden</span></div>
        <div class="j-stat"><span class="j-stat-val">{sorted[sorted.length - 1]?.data.date.slice(0,4) ?? '—'}</span><span class="j-stat-lbl mono">Since</span></div>
      </div>
    </div>

    <!-- City filters -->
    <div class="container">
      <div class="j-filters" id="filters">
        {cities.map(city => (
          <button class={`j-filter mono${city === 'All' ? ' active' : ''}`} data-city={city}>
            {city}
          </button>
        ))}
      </div>
    </div>

    <!-- Trip log -->
    <div class="container">
      <div class="j-log">
        <p class="j-log-header mono">{sorted.length} {sorted.length === 1 ? 'entry' : 'entries'} · sorted by date</p>

        {renderedTrips.map(({ trip, Content }) => (
          <article class="trip-entry" id={trip.id} data-city={trip.data.city}>
            <div class="trip-entry-meta">
              <span class="trip-entry-date mono">{trip.data.date}</span>
              <span class="trip-entry-city mono">{trip.data.city}</span>
              {trip.data.km && <span class="trip-entry-km mono">{trip.data.km}km</span>}
            </div>
            <div class="trip-entry-body">
              <h2 class="trip-entry-title">{trip.data.title}</h2>
              {trip.data.cover && (
                <img src={trip.data.cover} alt={trip.data.title} class="trip-entry-img" />
              )}
              <div class="trip-entry-content">
                <Content />
              </div>
              <div class="trip-entry-tags">
                {trip.data.tags.map(t => <span class="pill">{t}</span>)}
              </div>
            </div>
          </article>
        ))}
      </div>
    </div>

  </main>

  <footer class="footer">
    <div class="container footer-inner">
      <span class="mono">Ansh Goyal © {new Date().getFullYear()}</span>
      <a href="/" class="mono footer-back">← Back to portfolio</a>
    </div>
  </footer>
</Base>

<style>
.journey-page { padding-top: calc(var(--nav-h) + 4rem); padding-bottom: 6rem; }

.j-header { margin-bottom: 3rem; }
.j-eyebrow { font-size: 0.72rem; letter-spacing: 0.12em; margin-bottom: 1rem; }
.j-title {
  font-family: var(--font-display); font-weight: 900;
  font-size: clamp(4rem, 10vw, 8rem);
  line-height: 0.9; letter-spacing: -0.03em; margin-bottom: 1rem;
}
.j-sub { font-size: 0.75rem; color: var(--subtle); letter-spacing: 0.06em; }

.j-stats {
  display: grid; grid-template-columns: repeat(4, 1fr);
  gap: 1px; background: var(--border);
  border: 1px solid var(--border); border-radius: var(--radius);
  overflow: hidden; margin-bottom: 2.5rem;
}
.j-stat {
  background: var(--surface); padding: 1.5rem;
  display: flex; flex-direction: column; align-items: center;
}
.j-stat-val {
  font-family: var(--font-display); font-weight: 900;
  font-size: 2rem; line-height: 1; color: var(--accent);
}
.j-stat-lbl {
  font-size: 0.62rem; text-transform: uppercase;
  letter-spacing: 0.1em; color: var(--subtle); margin-top: 0.4rem;
}

.j-filters { display: flex; gap: 0.6rem; flex-wrap: wrap; margin-bottom: 2.5rem; }
.j-filter {
  font-size: 0.68rem; letter-spacing: 0.08em; text-transform: uppercase;
  padding: 0.4rem 1rem; border-radius: 999px;
  border: 1px solid var(--border-2); color: var(--subtle);
  background: transparent; transition: border-color 0.2s, color 0.2s, background 0.2s;
}
.j-filter:hover { border-color: var(--text); color: var(--text); }
.j-filter.active { border-color: var(--accent); color: var(--accent); background: rgba(255,107,53,0.06); }

.j-log { }
.j-log-header {
  font-size: 0.68rem; color: var(--subtle); letter-spacing: 0.1em;
  text-transform: uppercase; padding-bottom: 1.5rem;
  border-bottom: 1px solid var(--border); margin-bottom: 0;
}

.trip-entry {
  display: grid; grid-template-columns: 160px 1fr;
  gap: 2.5rem; padding: 2.5rem 0;
  border-bottom: 1px solid var(--border);
  transition: opacity 0.3s;
}
.trip-entry.hidden { display: none; }

.trip-entry-meta {
  display: flex; flex-direction: column; gap: 0.5rem;
  padding-top: 0.25rem; text-align: right;
  border-right: 1px solid var(--border); padding-right: 2rem;
}
.trip-entry-date { font-size: 0.7rem; color: var(--subtle); letter-spacing: 0.06em; }
.trip-entry-city { font-size: 0.65rem; color: var(--accent); letter-spacing: 0.1em; text-transform: uppercase; }
.trip-entry-km   { font-size: 0.65rem; color: var(--border-2); letter-spacing: 0.08em; }

.trip-entry-body { display: flex; flex-direction: column; gap: 1rem; }
.trip-entry-title {
  font-family: var(--font-display); font-weight: 700;
  font-size: clamp(1.5rem, 3vw, 2rem); letter-spacing: -0.02em; line-height: 1.1;
}
.trip-entry-img {
  width: 100%; max-height: 400px; object-fit: cover;
  border-radius: var(--radius); border: 1px solid var(--border);
}
.trip-entry-content { font-size: 1rem; color: var(--muted); line-height: 1.8; }
.trip-entry-tags { display: flex; flex-wrap: wrap; gap: 0.4rem; }

.footer { padding: 1.5rem 0; border-top: 1px solid var(--border); }
.footer-inner { display: flex; justify-content: space-between; align-items: center; font-size: 0.72rem; color: var(--subtle); }
.footer-back { transition: color 0.2s; }
.footer-back:hover { color: var(--accent); }

@media (max-width: 768px) {
  .trip-entry { grid-template-columns: 1fr; gap: 1rem; }
  .trip-entry-meta { text-align: left; border-right: none; padding-right: 0; flex-direction: row; flex-wrap: wrap; }
  .j-stats { grid-template-columns: repeat(2, 1fr); }
}
</style>

<script>
  const filters = document.querySelectorAll('.j-filter');
  const entries = document.querySelectorAll('.trip-entry') as NodeListOf<HTMLElement>;

  filters.forEach(btn => {
    btn.addEventListener('click', () => {
      filters.forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      const city = (btn as HTMLElement).dataset.city;
      entries.forEach(entry => {
        const match = city === 'All' || entry.dataset.city === city;
        entry.classList.toggle('hidden', !match);
      });
    });
  });
</script>